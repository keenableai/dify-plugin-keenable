# Remote debugging config for `python -m main`.
# Copy to `.env` (gitignored) and fill in from Dify → Plugin Management →
# "Debug" (remote server address + debugging Key).
INSTALL_METHOD=remote
REMOTE_INSTALL_HOST=debug.dify.ai
REMOTE_INSTALL_PORT=5003
REMOTE_INSTALL_KEY=

# Optional: point the plugin at a Keenable-compatible API base (HTTPS only;
# http allowed for loopback). Defaults to https://api.keenable.ai.
# KEENABLE_API_URL=https://api.keenable.ai
